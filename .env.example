# OpenClaw Docker 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============================================
# Anthropic API 配置（必需）
# ============================================

# Anthropic API 密钥（必需）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic API Base URL（可选，默认使用官方 API）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# Gateway 配置（必需）
# ============================================

# Gateway 认证 Token（必需）
# 生成方法: openssl rand -hex 24
GATEWAY_TOKEN=your_gateway_token_here

# ============================================
# Telegram 配置（可选）
# ============================================

# 是否启用 Telegram（true/false）
TELEGRAM_ENABLED=false

# Telegram Bot Token（如果启用 Telegram 则必需）
TELEGRAM_BOT_TOKEN=

# ============================================
# Tailscale 配置（可选）
# ============================================

# Tailscale Auth Key（如果使用 Tailscale 则必需）
# 获取方法: https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTH_KEY=tskey-auth-xxxxx

# ============================================
# 其他配置
# ============================================

# 时区
TZ=Asia/Shanghai

# ============================================
# 使用说明
# ============================================

# 1. 复制此文件:
#    cp .env.example .env

# 2. 编辑 .env 文件，填写实际值

# 3. 生成 Gateway Token:
#    openssl rand -hex 24

# 4. 启动服务:
#    docker-compose up -d

# 5. 查看日志:
#    docker-compose logs -f

# 6. 访问 Control UI:
#    http://localhost:9000/openclaw/
